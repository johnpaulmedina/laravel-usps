{
    "name": "johnpaulmedina/laravel-usps",
    "description": "USPS Addresses API v3 (OAuth2) for Laravel",
    "type": "library",
    "keywords": ["usps", "laravel", "address", "validation", "oauth2", "api-v3"],
    "authors": [
        {
            "name": "John Paul Medina",
            "email": "jp@leadtrust.io"
        }
    ],
    "homepage": "https://github.com/johnpaulmedina/laravel-usps/",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0 || ^11.0 || ^12.0 || ^13.0",
        "illuminate/http": "^10.0 || ^11.0 || ^12.0 || ^13.0",
        "illuminate/cache": "^10.0 || ^11.0 || ^12.0 || ^13.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0 || ^11.0",
        "orchestra/testbench": "^8.0 || ^9.0 || ^10.0 || ^11.0",
        "guzzlehttp/guzzle": "^7.0",
        "guzzlehttp/psr7": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Johnpaulmedina\\Usps\\": "src/Usps/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Johnpaulmedina\\Usps\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Johnpaulmedina\\Usps\\UspsServiceProvider"
            ],
            "aliases": {
                "Usps": "Johnpaulmedina\\Usps\\Facades\\Usps"
            }
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "minimum-stability": "stable"
}
